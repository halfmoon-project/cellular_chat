<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hm_bg_subtle">

    <ScrollView
        android:id="@+id/loginScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/hm_space_6">

            <Space
                android:layout_width="1dp"
                android:layout_height="@dimen/hm_space_16" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cellular Chat"
                android:textColor="@color/hm_fg_default"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/hm_space_2"
                android:gravity="center"
                android:text="인터넷 없이 같은 로컬 네트워크에서\n채팅하고 파일을 옮기세요."
                android:textColor="@color/hm_fg_muted"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/hm_space_8"
                android:background="@drawable/panel_background"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="표시 이름"
                    android:textColor="@color/hm_fg_default"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/displayNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="예: 민수"
                    android:imeOptions="actionNext"
                    android:inputType="textPersonName"
                    android:maxLength="40"
                    android:singleLine="true"
                    android:textColor="@color/hm_fg_default"
                    android:textColorHint="@color/hm_fg_subtle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/hm_space_3"
                    android:text="연결 ID"
                    android:textColor="@color/hm_fg_default"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/connectionIdInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="영문·숫자·하이픈 6~32자"
                    android:imeOptions="actionDone"
                    android:inputType="textPassword"
                    android:maxLength="32"
                    android:singleLine="true"
                    android:textColor="@color/hm_fg_default"
                    android:textColorHint="@color/hm_fg_subtle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/hm_space_2"
                    android:text="두 기기에 같은 ID를 입력하세요. 짧은 ID는 주변에서 추측할 수 있으니 임의의 긴 ID를 권장합니다."
                    android:textColor="@color/hm_fg_muted"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/connectButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="@dimen/hm_space_6"
                    android:background="@drawable/button_primary"
                    android:text="연결 시작"
                    android:textColor="@color/hm_action_primary_fg"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/sessionPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/hm_space_4"
        android:visibility="gone">

        <TextView
            android:id="@+id/networkStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="연결 준비 중"
            android:textColor="@color/hm_fg_muted"
            android:textSize="13sp" />

        <Button
            android:id="@+id/leaveButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_gravity="end"
            android:text="나가기" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/hm_space_3"
            android:background="@drawable/panel_background"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/rangingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="정밀 찾기"
                android:textColor="@color/hm_fg_default"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.cellularchat.app.DirectionView
                android:id="@+id/directionView"
                android:layout_width="170dp"
                android:layout_height="120dp"
                android:layout_marginTop="@dimen/hm_space_1" />

            <TextView
                android:id="@+id/distanceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/hm_fg_default"
                android:textSize="25sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rangingStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="지원 여부 확인 중"
                android:textColor="@color/hm_fg_muted"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/hm_space_2"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/startRangingButton"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="친구 찾기" />

                <Button
                    android:id="@+id/stopRangingButton"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="@dimen/hm_space_2"
                    android:text="중지" />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:id="@+id/chatScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/hm_space_3"
            android:layout_weight="1"
            android:background="@drawable/panel_background"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/chatContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/hm_space_2"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/attachButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="파일 보내기"
                android:text="＋"
                android:textSize="22sp" />

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="@dimen/hm_space_2"
                android:layout_weight="1"
                android:hint="메시지"
                android:imeOptions="actionSend"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLength="8000"
                android:maxLines="3"
                android:textColor="@color/hm_fg_default"
                android:textColorHint="@color/hm_fg_subtle" />

            <Button
                android:id="@+id/sendButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="전송" />
        </LinearLayout>

        <Button
            android:id="@+id/shareLastFileButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="최근 받은 파일 공유"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
